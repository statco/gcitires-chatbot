{
  "version": 2,
  "functions": {
    "api/chat.ts": {
      "maxDuration": 30
    },
    "api/order.ts": {
      "maxDuration": 15
    },
    "api/memory.ts": {
      "maxDuration": 15
    },
    "api/detect-language.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "outputDirectory": "widget/dist"
}