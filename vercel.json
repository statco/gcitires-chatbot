{
  "version": 2,
  "functions": {
    "api/chat.ts": {
      "maxDuration": 30
    },
    "api/order.ts": {
      "maxDuration": 15
    },
    "api/memory.ts": {
      "maxDuration": 15
    },
    "api/detect-language.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://gcitires.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, X-Customer-ID, X-Session-ID"
        },
        {
          "key": "Access-Control-Max-Age",
          "value": "86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
