    "build": "cd widget && npm install && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "airtable": "^0.12.2",
    "franc-min": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/node": "^3.0.0",
    "typescript": "^5.3.3"
  }
}