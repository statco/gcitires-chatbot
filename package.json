{
  "name": "gcitires-chatbot",
  "version": "1.0.0",
  "private": true,
  "description": "Bilingual AI chatbot for GCI Tires — Vercel serverless backend",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "build:widget": "cd widget && npm run build",
